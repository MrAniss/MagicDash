GOOGLE_ADS_ID_PARAPHARMACIE_LAFAYETTE_FR=
GOOGLE_ADS_ID_LASANTE_FR=

# Conversion action IDs for POAS / margin queries
# (numeric ID only — the customer prefix is built from the account ID at runtime)
