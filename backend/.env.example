MC_ID_PARAPHARMACIE_LAFAYETTE_FR=
MC_ID_LASANTE_FR=

# ─── Meta Marketing API (Paid Social) ─────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# One ad account ID per market. Markets without a value here are hidden
# from the Paid Social view at runtime.
META_AD_ACCOUNT_ID_FR=
META_AD_ACCOUNT_ID_UK=
META_AD_ACCOUNT_ID_DE=
META_AD_ACCOUNT_ID_ES=
META_AD_ACCOUNT_ID_IT=

# ─── Budget Google Sheet ──────────────────────────────────
# Spreadsheet that drives the Budget tab (Cocooncenter + Para. Lafayette
# in tab "Raw_Import", Pascal Coste in tab "PCS_Budget").
BUDGET_SHEET_ID=

# ─── User auth (JWT signing key) ──────────────────────────
# Random string >= 16 chars used to sign session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

PORT=3001
