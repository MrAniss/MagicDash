GA4_PROPERTY_COCOONCENTER_RO=
GA4_PROPERTY_COCOONCENTER_FI=
GA4_PROPERTY_COCOONCENTER_SE=
GA4_PROPERTY_COCOONCENTER_IE=

# ─── Merchant Center IDs ──────────────────────────────────
# US/CA/AU/SA/NO/IE share the UK MC at runtime
MC_ID_COCOONCENTER_FR=
MC_ID_COCOONCENTER_BE=
MC_ID_COCOONCENTER_UK=
MC_ID_COCOONCENTER_DE=
MC_ID_COCOONCENTER_ES=
