# ─── GA4 Properties ───────────────────────────────────────
# Brand-level rollups
GA4_PROPERTY_COCOONCENTER=
GA4_PROPERTY_PASCAL_COSTE=
GA4_PROPERTY_PARAPHARMACIE_LAFAYETTE=
GA4_PROPERTY_LASANTE=

# Cocooncenter market-level (NO/SA/CA/AU/US share the UK property)
GA4_PROPERTY_COCOONCENTER_FR=
GA4_PROPERTY_COCOONCENTER_UK=
GA4_PROPERTY_COCOONCENTER_BE=
GA4_PROPERTY_COCOONCENTER_DE=
GA4_PROPERTY_COCOONCENTER_ES=
GA4_PROPERTY_COCOONCENTER_IT=
GA4_PROPERTY_COCOONCENTER_PL=
