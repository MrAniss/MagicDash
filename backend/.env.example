GOOGLE_ADS_ID_BRAND_A_FI=
GOOGLE_ADS_ID_BRAND_A_PL=
GOOGLE_ADS_ID_BRAND_A_IE=
GOOGLE_ADS_ID_BRAND_A_RO=
GOOGLE_ADS_ID_BRAND_A_SA=
GOOGLE_ADS_ID_BRAND_A_CA=
GOOGLE_ADS_ID_BRAND_A_AU=
GOOGLE_ADS_ID_BRAND_A_US=

# Standalone brands
GOOGLE_ADS_ID_BRAND_B_FR=
GOOGLE_ADS_ID_BRAND_C_FR=
GOOGLE_ADS_ID_BRAND_D_FR=

# Conversion action IDs for POAS / margin queries
# (numeric ID only — the customer prefix is built from the account ID at runtime)
GOOGLE_ADS_MARGIN_CONVERSION_BRAND_A_FR=

# ─── GA4 Properties ───────────────────────────────────────
# Brand-level rollups
GA4_PROPERTY_BRAND_A=
GA4_PROPERTY_BRAND_B=
GA4_PROPERTY_BRAND_C=
GA4_PROPERTY_BRAND_D=

# Brand Alpha market-level (NO/SA/CA/AU/US share the UK property)
GA4_PROPERTY_BRAND_A_FR=
GA4_PROPERTY_BRAND_A_UK=
GA4_PROPERTY_BRAND_A_BE=
GA4_PROPERTY_BRAND_A_DE=
GA4_PROPERTY_BRAND_A_ES=
GA4_PROPERTY_BRAND_A_IT=
GA4_PROPERTY_BRAND_A_PL=
GA4_PROPERTY_BRAND_A_NL=
GA4_PROPERTY_BRAND_A_AT=
GA4_PROPERTY_BRAND_A_PT=
GA4_PROPERTY_BRAND_A_LU=
GA4_PROPERTY_BRAND_A_RO=
GA4_PROPERTY_BRAND_A_FI=
GA4_PROPERTY_BRAND_A_SE=
GA4_PROPERTY_BRAND_A_IE=

# ─── Merchant Center IDs ──────────────────────────────────
# US/CA/AU/SA/NO/IE share the UK MC at runtime
MC_ID_BRAND_A_FR=
MC_ID_BRAND_A_BE=
MC_ID_BRAND_A_UK=
MC_ID_BRAND_A_DE=
MC_ID_BRAND_A_ES=
MC_ID_BRAND_A_IT=
MC_ID_BRAND_A_AT=
MC_ID_BRAND_A_FI=
MC_ID_BRAND_A_IE=
MC_ID_BRAND_A_NL=
MC_ID_BRAND_A_PL=
MC_ID_BRAND_A_PT=
MC_ID_BRAND_A_RO=
MC_ID_BRAND_A_SE=
MC_ID_BRAND_B_FR=
MC_ID_BRAND_C_FR=
MC_ID_BRAND_D_FR=

# ─── Meta Marketing API (Paid Social) ─────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# One ad account ID per market. Markets without a value here are hidden
# from the Paid Social view at runtime.
META_AD_ACCOUNT_ID_FR=
META_AD_ACCOUNT_ID_UK=
META_AD_ACCOUNT_ID_DE=
META_AD_ACCOUNT_ID_ES=
META_AD_ACCOUNT_ID_IT=

# ─── Budget Google Sheet ──────────────────────────────────
# Spreadsheet that drives the Budget tab (Brand Alpha + Brand Gamma
# in tab "Raw_Import", Brand Beta in tab "Brand_B_Budget").
BUDGET_SHEET_ID=

# ─── User auth (JWT signing key) ──────────────────────────
# Random string >= 16 chars used to sign session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

PORT=3001
