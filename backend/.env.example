GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Google Ads Customer IDs (one per brand × market) ────
# Markets without an env value are skipped at runtime.
GOOGLE_ADS_MCC_ID=

# Brand Alpha (MCC sub-accounts)
GOOGLE_ADS_ID_BRAND_A_FR=
GOOGLE_ADS_ID_BRAND_A_BE=
GOOGLE_ADS_ID_BRAND_A_NL=
GOOGLE_ADS_ID_BRAND_A_DE=
GOOGLE_ADS_ID_BRAND_A_IT=
